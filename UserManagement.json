{
    "openapi": "3.0.4",
    "info": {
        "title": "User Management API",
        "description": ".NET Core Web API CRUD and Authentication",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "https://localhost:7122",
            "description": "Local Server"
        }
    ],
    "tags": [
        {
            "name": "Auth",
            "description": "Login"
        },
        {
            "name": "User",
            "description": "CRUD"
        }
    ],
    "paths": {
        "/api/v1/auth/login":{
            "post":{
                "tags": ["Auth"],
                "summary": "Authenticates user",
                "requestBody":{
                    "content": {
                        "application/json":{
                            "schema":{
                                "$ref": "#/components/schemas/LoginRequestModel"
                            }
                        }
                    }
                },
                "responses": {
                    "200":{
                        "description": "User authenticated successfully.",
                        "content": {
                            "application/json":{
                                "schema":{
                                    "$ref": "#/components/schemas/LoginResponseModel"
                                }
                            }
                        }
                    },
                    "400":{
                        "description": "Request validation failed — required fields are missing or have invalid format",
                        "content": {
                            "text/plain":{
                                "schema":{
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "404":{
                        "description": "No user found with the given Email.",
                        "content": {
                            "text/plain":{
                                "schema":{
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "401":{
                        "description": "No existing user found. Invalid credentials",
                        "content": {
                            "text/plain":{
                                "schema":{
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                "security": []
            }
        },
        "/api/v1/users":{
            "post":{
                "tags": ["User"],
                "summary": "Creates a new user",
                "requestBody":{
                    "content": {
                        "application/json":{
                            "schema":{
                                "$ref": "#/components/schemas/CreateUserRequestModel"
                            }
                        }
                    }
                },
                "responses": {
                    "201":{
                        "description": "User created successfully",
                        "headers": {
                            "Location":{
                                "description": "URL of the newly created user.",
                                "schema":{
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json":{
                                "schema":{
                                    "$ref": "#/components/schemas/UserResponseModel"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Request validation failed — required fields are missing or have invalid format",
                        "content": {
                            "text/plain":{
                                "schema":{
                                    "type": "string"
                                }
                            }
                        }
                    }
                }         
            },
            "get":{
                "tags": ["User"],
                "summary": "Get all users for listing",
                "responses": {
                    "200":{
                        "description": "Return all existing users",
                        "content": {
                            "application/json":{
                                "schema":{
                                    "$ref": "#/components/schemas/UserSummaryModel"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/users/{id}":{
            "get":{
                "tags": ["User"],
                "summary": "Get user for the given id",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema":{
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "200":{
                        "description": "Returns user for the given id",
                        "content": {
                            "application/json":{
                                "schema":{
                                    "$ref": "#/components/schemas/UserResponseModel"
                                }
                            }
                        }
                    },
                    "400":{
                        "description": "Request validation failed — required fields are missing or have invalid format",
                        "content": {
                            "text/plain":{
                                "schema":{
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            },
            "put":{
                "tags": ["User"],
                "summary": "Update user for the given id",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema":{
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "requestBody":{
                    "content": {
                        "application/json":{
                            "schema":{
                                "$ref": "#/components/schemas/UpdateUserRequestModel"
                            }
                        }
                    }
                },
                "responses": {
                    "200":{
                        "description": "User updated successfully",
                        "content": {
                            "application/json":{
                                "schema":{
                                    "$ref": "#/components/schemas/UserResponseModel"
                                }
                            }
                        }
                    },
                    "400":{
                        "description": "Request validation failed — required fields are missing or have invalid format",
                        "content": {
                            "text/plain":{
                                "schema":{
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            },
            "delete":{
                "tags": ["User"],
                "summary": "Removes user from database by id",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema":{
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "204":{
                        "description": "User deleted successfully and returns no content",
                        "content": {
                            "text/plain":{
                                "schema":{
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "400":{
                        "description": "Request validation failed — required fields are missing or have invalid format",
                        "content": {
                            "text/plain":{
                                "schema":{
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "CreateUserRequestModel":{
                "type": "object",
                "required": [
                    "fullName", 
                    "email", 
                    "password"
                ],
                "properties": {
                    "fullName":{
                        "type": "string",
                        "minLength": 2,
                        "maxLength": 100
                    },
                    "email":{
                        "type": "string",
                        "format": "email",
                        "maxLength": 200
                    },
                    "password":{
                        "type": "string",
                        "format": "password",
                        "minLength": 6
                    }
                }
            },
            "LoginRequestModel":{
                "type": "object",
                "required": [
                    "email", 
                    "password"
                ],
                "properties": {
                    "email":{
                        "type": "string",
                        "format": "email",
                        "maxLength": 200
                    },
                    "password":{
                        "type": "string",
                        "format": "password",
                        "minLength": 6
                    }
                }
            },
            "LoginResponseModel":{
                "type": "object",
                "properties": {
                    "fullName":{
                        "type": "string"
                    },
                    "email":{
                        "type": "string"
                    },
                    "role":{
                        "type": "string"
                    },
                    "accessToken":{
                        "type": "string"
                    }
                }
            },
            "UpdateUserRequestModel":{
                "type": "object",
                "required": [
                    "fullName"
                ],
                "properties": {
                    "fullName":{
                        "type": "string",
                        "minLength": 2,
                        "maxLength": 100
                    },
                    "email":{
                        "type": "string",
                        "nullable": true,
                        "format": "email",
                        "maxLength": 200
                    },
                    "password":{
                        "type": "string",
                        "nullable": true,
                        "format": "password",
                        "minLength": 6
                    }
                }
            },
            "UserResponseModel":{
                "type": "object",
                "properties": {
                    "id":{
                        "type": "string",
                        "format": "uuid"
                    },
                    "fullName":{
                        "type": "string"
                    },
                    "email":{
                        "type": "string"
                    },
                    "role":{
                        "type": "string"
                    },
                    "createdAt":{
                        "type": "string"
                    },
                    "updatedAt":{
                        "type": "string"
                    }
                }
            },
            "UserSummaryModel":{
                "type": "object",
                "properties": {
                    "id":{
                        "type": "string",
                        "format": "uuid"
                    },
                    "fullName":{
                        "type": "string"
                    },
                    "email":{
                        "type": "string"
                    }
                }
            }
        },
        "securitySchemes": {
            "Bearer":{
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT",
                "description": "Enter: Bearer {your-token}"
            }
        }
    },
    "security": [
        {
            "Bearer": []
        }
    ]
}